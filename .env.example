# ARIA-PI environment variables
# Copy this file to .env and fill in real values.

# Required
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Recommended (raises NCBI rate limit from 3 req/s to 10 req/s)
NCBI_API_KEY=
NCBI_EMAIL=

# Optional — used as polite-pool identifier for OpenAlex and SEC EDGAR
ARIA_PI_CONTACT_EMAIL=
